<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Project Submission Portal</display-name>

    <!-- ======================== Servlets ======================== -->

    <servlet>
        <servlet-name>SubmitProjectServlet</servlet-name>
        <servlet-class>servlet.SubmitProjectServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>ViewProjectsServlet</servlet-name>
        <servlet-class>servlet.ViewProjectsServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>UpdateStatusServlet</servlet-name>
        <servlet-class>servlet.UpdateStatusServlet</servlet-class>
    </servlet>

    <!-- ==================== Servlet Mappings ==================== -->

    <servlet-mapping>
        <servlet-name>SubmitProjectServlet</servlet-name>
        <url-pattern>/submitProject</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>ViewProjectsServlet</servlet-name>
        <url-pattern>/viewProjects</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>UpdateStatusServlet</servlet-name>
        <url-pattern>/updateStatus</url-pattern>
    </servlet-mapping>

    <!-- ==================== Welcome File ======================== -->

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ==================== Error Pages ========================= -->

    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

</web-app>
